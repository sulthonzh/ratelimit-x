{
  "name": "ratelimit-x",
  "version": "1.1.0",
  "description": "Zero-dependency rate limiting for Node.js — Token Bucket, Sliding Window, Fixed Window, Leaky Bucket",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test test/test.mjs",
    "test:coverage": "c8 node --test test/test.mjs",
    "test:core": "node --test test/test.mjs",
    "lint": "eslint src/ test/",
    "prepublishOnly": "npm test",
    "build": "rollup -c"
  },
  "keywords": [
    "rate-limit",
    "rate-limiting",
    "token-bucket",
    "sliding-window",
    "leaky-bucket",
    "fixed-window",
    "throttle",
    "zero-dependency"
  ],
  "license": "MIT",
  "author": "sulthonzh",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sulthonzh/ratelimit-x.git"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "c8": "^10.1.3",
    "eslint": "^9.0.0",
    "globals": "^17.0.0",
    "rollup": "^4.62.0"
  }
}